---
import '../styles/fonts.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'EC²R — Mobiliser les énergies collectives',
  description = 'Méthode EC²R : identifier chirurgicalement les leviers de mobilisation collective pour passer à l\'acte. Développement professionnel, pas personnel.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fr" data-lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <style>
    /* i18n : masque les blocs de la langue inactive avant JS */
    [data-lang="fr"] [data-i18n-lang="en"] { display: none !important; }
    [data-lang="en"] [data-i18n-lang="fr"] { display: none !important; }
  </style>
  
  <!-- OG -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="fr_FR" />
  
  <title>{title}</title>
  
  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/images/logo-ec2r.png" />
</head>
<body>
  <slot />

  <script>
    // ── i18n global ──────────────────────────────────────────────────
    // Tous les éléments avec data-i18n ont aussi data-i18n-fr et data-i18n-en
    function applyI18n(lang: string) {
      document.querySelectorAll<HTMLElement>('[data-i18n-fr]').forEach(el => {
        const val = lang === 'en' ? el.dataset.i18nEn : el.dataset.i18nFr;
        if (val !== undefined) el.textContent = val;
      });
      // lang attr sur html
      document.documentElement.setAttribute('lang', lang);
    }

    // Écoute les changements de data-lang sur <html>
    new MutationObserver(() => {
      applyI18n(document.documentElement.getAttribute('data-lang') || 'fr');
    }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });

    // Init au chargement
    document.addEventListener('DOMContentLoaded', () => {
      applyI18n(document.documentElement.getAttribute('data-lang') || 'fr');
    });

    // Scroll reveal
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

    // Active nav on scroll
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav-link');

    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY + 100;
      sections.forEach((section) => {
        const sectionEl = section as HTMLElement;
        const top = sectionEl.offsetTop;
        const height = sectionEl.offsetHeight;
        const id = sectionEl.getAttribute('id');
        if (scrollY >= top && scrollY < top + height) {
          navLinks.forEach((link) => {
            link.classList.remove('active');
            if (link.getAttribute('href') === `#${id}`) {
              link.classList.add('active');
            }
          });
        }
      });
    });
  </script>
</body>
</html>
