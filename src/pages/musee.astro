---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Petit musée EC²R — En cours de finalisation" description="Le petit musée de la Méthode EC²R : photos, moments clés, slides et outils. Page en cours de finalisation.">
  <main class="min-h-screen bg-navy-950 flex items-center justify-center px-6">
    <div class="max-w-2xl text-center">
      <p class="text-energy-green text-sm font-semibold tracking-[0.2em] uppercase mb-4">
        Petit musée EC²R
      </p>
      <h1 class="text-3xl md:text-5xl font-display font-extrabold text-white leading-tight mb-6">
        À venir<span class="text-energy-green">.</span>
      </h1>
      <p class="text-white/60 text-base md:text-lg leading-relaxed mb-2">
        Cette page est <strong class="text-energy-green">en cours de finalisation</strong>.
      </p>
      <p class="text-white/40 text-sm leading-relaxed mb-8">
        Photos, moments clés, slides originels, outils d'aide à la vente, micro-éléments
        montrant le chemin parcouru depuis 2021. Ouvert prochainement.
      </p>
      <a href="/" class="inline-flex items-center gap-2 px-5 py-2.5 bg-white/5 hover:bg-white/10
             border border-white/20 hover:border-white/40 text-white text-sm font-semibold
             rounded-lg transition-all">
        ← Retour à la Méthode EC²R
      </a>
    </div>
  </main>
</Layout>
