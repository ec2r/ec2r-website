---
/**
 * Univers 5 : "Les praticiens" — VERSION V3 COMPLÈTE
 * Merge de : LesPraticiens.astro (v2) + Equipe.astro (v1)
 * 
 * Structure :
 * 1. Titre + baseline différenciation
 * 2. Founders (2 grandes cartes avec bios complètes)
 * 3. Équipe praticiens (4 cartes moyennes)
 * 4. Teaser "Sur le terrain" (photos séminaires à venir)
 */
interface Props { fr: any; en: any; }
const { fr, en } = Astro.props;

// Toute l'équipe dans une seule liste — layout géré par la grille CSS
const team = [
  {
    name: 'Stéphane', namePlus: 'FLAHAUT',
    initials: 'SF', photo: '/photos/equipe/flahaut.webp',
    linkedin: 'https://www.linkedin.com/in/stephane-flahaut',
    roleFr: 'Fondateur de la méthode EC²R et du protocole augmenté',
    roleEn: 'Founder of the EC²R method and augmented protocol',
    bioFr: "Porte et incarne la méthode EC²R depuis plus de 5 ans. Accompagne des collectifs vers la performance depuis plus de 20 ans. Assure l'amélioration continue de la méthode — garant, avec l'IA, de son intégrité et de son développement.",
    bioEn: "Carries and embodies the EC²R method for over 5 years. Supports collectives towards performance for over 20 years. Ensures continuous improvement — guardian, with AI, of the method's integrity and development.",
    size: 'hero', photoPos: 'center 20%',
  },
  {
    name: 'Luc', namePlus: 'LÉTOFFÉ',
    initials: 'LL', photo: '/photos/equipe/letoffe.webp',
    linkedin: '',
    roleFr: 'Genèse technique de la méthode EC²R et du protocole augmenté',
    roleEn: 'Technical genesis of the EC²R method and augmented protocol',
    bioFr: "Passe de l'idéation à la situation. Co-construit la promesse de valeur avec les experts métiers, traduit en produit, fait passer de l'idée à l'acte — en direct, avec vous.",
    bioEn: "Moves from ideation to situation. Co-builds the value promise with business experts, translates into product, moves from idea to action — directly, with you.",
    size: 'regular', photoPos: 'center 50%',
  },
  {
    name: 'Marie-Emilia', namePlus: 'GARCIA',
    initials: 'MEG', photo: '/photos/equipe/garcia.webp',
    linkedin: '',
    roleFr: 'Facilitatrice EC²R — Logistique, team, déploiement',
    roleEn: 'EC²R Facilitator — Logistics, team, deployment',
    bioFr: "Facilite le déploiement des sessions EC²R, coordonne la logistique team. Formée aux débriefs de profils individuels.",
    bioEn: "Facilitates EC²R session deployment, coordinates team logistics. Trained in individual profile debriefs.",
    size: 'regular', photoPos: 'center 15%',
  },
  {
    name: 'Jean-François', namePlus: 'MORIN',
    initials: 'JFM', photo: '/photos/equipe/morin.webp',
    linkedin: '',
    roleFr: 'Cofondateur EC²R Conseil',
    roleEn: 'Co-founder EC²R Conseil',
    bioFr: "Entraîneur d'entraîneurs et de sportifs professionnels, de champions. Ancrage terrain et transmission. Associé depuis les origines de la méthode EC²R.",
    bioEn: "Coaches' coach and trainer of professional athletes and champions. Field grounding and transmission. Partner since the origins of the EC²R method.",
    size: 'regular', photoPos: 'center top',
  },
  {
    name: 'Arnaud', namePlus: 'BOCHURBERG',
    initials: 'AB', photo: '/photos/equipe/arnaud-bochurberg.webp',
    linkedin: '',
    roleFr: 'Associé EC²R Conseil — Expert en profilage comportemental',
    roleEn: 'EC²R Conseil Partner — Behavioural profiling expert',
    bioFr: "Président du Groupe Alard. Professeur associé en Psycho-sociologie de la Communication à l'Université Gustave Eiffel depuis 28 ans. Conférencier, formateur et coach de dirigeants. Officier des Palmes Académiques. 1750+ leaders accompagnés.",
    bioEn: "President of Groupe Alard. Associate Professor in Psycho-sociology of Communication at Gustave Eiffel University for 28 years. Speaker, trainer and executive coach. Officer of the Palmes Académiques. 1750+ leaders supported.",
    size: 'regular', photoPos: 'center 20%',
  },
  {
    name: 'Jean', namePlus: 'ZUCCARELLI',
    initials: 'JZ', photo: '/photos/equipe/zuccarelli.webp',
    linkedin: 'https://www.linkedin.com/in/jean-zuccarelli-0807796/',
    roleFr: 'Associé EC²R Conseil — Praticien EC²R',
    roleEn: 'EC²R Conseil Partner — EC²R Practitioner',
    bioFr: "Accompagne les organisations dans la mise en acte de la méthode.",
    bioEn: "Supports organisations in implementing the method.",
    size: 'regular', photoPos: 'center 25%',
  },
];

// Teaser séminaires
const seminairePlaceholders = [
  { labelFr: 'Séminaire Laforêt 2024', labelEn: 'Laforêt seminar 2024' },
  { labelFr: 'Diagnostic collectif IRM+', labelEn: 'Collective IRM+ diagnosis' },
  { labelFr: 'Passage à l\'acte terrain', labelEn: 'Field action deployment' },
  { labelFr: 'Co-design en session', labelEn: 'Co-design in session' },
];
---

<div class="min-h-full bg-navy-950 relative">
  <div class="absolute inset-0 bg-gradient-to-bl from-navy-900/30 via-navy-950 to-navy-950"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14 space-y-12">

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- 1. TITRE : PRATICIENS + PRESCRIPTEURS -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div>
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-display font-extrabold text-white mb-3">
        <span data-i18n-lang="fr">Praticiens certifiés qui vous aident à passer à l'acte</span>
        <span data-i18n-lang="en">Certified practitioners who help you take action</span>
      </h2>
      <p class="text-white/40 text-sm mb-3 italic">
        <span data-i18n-lang="fr">Pas des consultants interchangeables, pas des associés ou des seniors et ensuite des juniors.</span>
        <span data-i18n-lang="en">Not interchangeable consultants, not partners or seniors then juniors.</span>
      </p>
      <p class="text-white/50 text-sm leading-relaxed max-w-3xl">
        <span data-i18n-lang="fr">Des professionnels et des humains qui ont expérimenté, qui croient à la différenciation de la méthode, qui savent dans chaque étape comment vous la faire vivre et traduire dans votre quotidien. La méthode à votre service, pas l'inverse.</span>
        <span data-i18n-lang="en">Professionals and humans who have experienced it, who believe in the method's differentiation, who know at every stage how to bring it to life and translate it into your daily reality. The method at your service, not the other way around.</span>
      </p>
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- 2. ÉQUIPE — Grille unifiée 3 colonnes                               -->
    <!--    Stéphane = 2col × 2row (hero), reste = 1×1 chacun                -->
    <!--    Layout :  [Stéphane] [Stéphane] [Luc     ]                        -->
    <!--              [Stéphane] [Stéphane] [Emilia  ]                        -->
    <!--              [JF Morin] [Arnaud  ] [Jean Z  ]                        -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 auto-rows-fr">
      {team.map((member) => member.size === 'hero' ? (
        <!-- ── Carte hero : Stéphane (2col × 2row) ── -->
        <div class="sm:col-span-2 sm:row-span-2 bg-white/[0.02] border border-white/[0.06] rounded-2xl overflow-hidden hover:border-white/15 transition-all group flex flex-col">
          <div class="flex-1 min-h-[280px] bg-gradient-to-br from-navy-900 via-navy-950 to-navy-900 
                      relative flex items-center justify-center overflow-hidden">
            {member.photo ? (
              <img src={member.photo} alt={`${member.name} ${member.namePlus}`}
                   class="absolute inset-0 w-full h-full object-cover"
                   style={`object-position: ${member.photoPos}`}
                   loading="lazy" />
            ) : (
              <div class="text-center relative z-10">
                <div class="w-24 h-24 rounded-full bg-white/[0.08] border border-white/10 mx-auto mb-3 
                            flex items-center justify-center backdrop-blur-sm">
                  <span class="text-white/50 text-2xl font-display font-bold">{member.initials}</span>
                </div>
              </div>
            )}
          </div>
          <div class="p-5">
            <h3 class="font-display font-bold text-xl text-white mb-1 flex items-center gap-2">
              {member.name}<span class="plus-accent">+</span> {member.namePlus}
              {member.linkedin && (
                <a href={member.linkedin} target="_blank" rel="noopener" 
                   class="text-white/20 hover:text-energy-green text-xs transition-colors ml-auto">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
              )}
            </h3>
            <p class="text-energy-green font-semibold text-sm mb-2">
              <span data-i18n-lang="fr">{member.roleFr}</span>
              <span data-i18n-lang="en">{member.roleEn}</span>
            </p>
            <p class="text-white/60 text-sm leading-relaxed">
              <span data-i18n-lang="fr">{member.bioFr}</span>
              <span data-i18n-lang="en">{member.bioEn}</span>
            </p>
          </div>
        </div>
      ) : (
        <!-- ── Carte regular : 1 colonne ── -->
        <div class="bg-white/[0.02] border border-white/[0.06] rounded-2xl overflow-hidden hover:border-white/15 transition-all group flex flex-col">
          <div class="aspect-[4/3] bg-gradient-to-br from-navy-900 via-navy-950 to-navy-900 
                      relative flex items-center justify-center overflow-hidden">
            {member.photo ? (
              <img src={member.photo} alt={`${member.name} ${member.namePlus}`}
                   class="absolute inset-0 w-full h-full object-cover"
                   style={`object-position: ${member.photoPos}`}
                   loading="lazy" />
            ) : (
              <div class="text-center relative z-10">
                <div class="w-16 h-16 rounded-full bg-white/[0.08] border border-white/10 mx-auto mb-2 
                            flex items-center justify-center backdrop-blur-sm
                            group-hover:border-energy-green/30 transition-colors duration-500">
                  <span class="text-white/50 text-lg font-display font-bold group-hover:text-energy-green/70 transition-colors">
                    {member.initials}
                  </span>
                </div>
              </div>
            )}
          </div>
          <div class="p-4 flex-1 flex flex-col">
            <h4 class="font-display font-bold text-sm text-white mb-1 flex items-center gap-1">
              {member.name}<span class="plus-accent text-xs">+</span> {member.namePlus}
              {member.linkedin && (
                <a href={member.linkedin} target="_blank" rel="noopener" 
                   class="text-white/20 hover:text-energy-green text-xs transition-colors ml-auto">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
              )}
            </h4>
            <p class="text-energy-green/80 font-semibold text-xs mb-2">
              <span data-i18n-lang="fr">{member.roleFr}</span>
              <span data-i18n-lang="en">{member.roleEn}</span>
            </p>
            <p class="text-white/50 text-[11px] leading-relaxed flex-1">
              <span data-i18n-lang="fr">{member.bioFr}</span>
              <span data-i18n-lang="en">{member.bioEn}</span>
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- 4. PRESCRIPTEURS : Ils l'ont vécu ou ils veulent nous recommander -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div>
      <h3 class="text-lg font-display font-bold text-white/70 mb-4 uppercase tracking-wider text-xs">
        <span data-i18n-lang="fr">Prescripteurs</span>
        <span data-i18n-lang="en">Prescribers</span>
      </h3>
      <div class="bg-white/[0.02] border border-white/[0.06] rounded-xl p-8 text-center">
        <p class="text-white/50 text-sm leading-relaxed max-w-2xl mx-auto mb-4">
          <span data-i18n-lang="fr">Ils l'ont vécu ou ils veulent nous recommander</span>
          <span data-i18n-lang="en">They experienced it or they want to recommend us</span>
        </p>
        <p class="text-white/30 text-xs italic">
          <span data-i18n-lang="fr">Section en construction</span>
          <span data-i18n-lang="en">Under construction</span>
        </p>
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- 5. LIEN LINKEDIN EC²R -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div class="text-center">
      <a href="https://www.linkedin.com/company/ec2r-conseil" target="_blank" rel="noopener"
         class="inline-flex items-center gap-2 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 
                text-white text-sm font-semibold px-6 py-3 rounded-lg transition-all group">
        <svg class="w-5 h-5 text-white/70 group-hover:text-energy-green transition-colors" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        <span data-i18n-lang="fr">Suivre EC²R sur LinkedIn</span>
        <span data-i18n-lang="en">Follow EC²R on LinkedIn</span>
      </a>
    </div>

  </div>
</div>
