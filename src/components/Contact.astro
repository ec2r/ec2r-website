---
/*
  Section contact v2 — segmentation + touch arrogant + booking.
  "Pas de formulaire commercial, pas d'agent conversationnel, 
   une vraie discussion courte de 10 minutes pour voir si ça résonne."
*/
---

<section id="contact" class="py-24 lg:py-32 bg-navy-950 relative overflow-hidden">
  <!-- Subtle background decoration -->
  <div class="absolute top-0 left-0 right-0 energy-gradient-bar h-1"></div>
  <div class="absolute bottom-1/4 right-0 w-[500px] h-[500px] rounded-full border border-white/[0.03] translate-x-1/2"></div>
  <div class="absolute inset-0 grid-overlay"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
    
    <!-- Segmentation intro -->
    <div class="max-w-3xl mx-auto text-center mb-16 reveal">
      <p class="text-energy-green text-sm font-semibold tracking-[0.2em] uppercase mb-6">Parlons-en</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-bold text-white leading-tight mb-8">
        Un échange rapide,<br/>
        <span class="text-white/50">pas un pitch.</span>
      </h2>
      <p class="text-white/50 text-lg leading-relaxed max-w-xl mx-auto">
        Pas de formulaire commercial. Pas d'agent conversationnel. 
        Une vraie discussion courte de 10 minutes pour voir si ça résonne.
      </p>
    </div>

    <!-- Segmentation cards -->
    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto mb-16">
      
      <!-- Card: Co-constructeurs -->
      <div class="reveal reveal-delay-1">
        <div class="bg-white/[0.06] backdrop-blur-sm rounded-2xl p-8 border border-energy-green/20 
                    hover:border-energy-green/40 transition-all duration-300 h-full">
          <div class="w-12 h-12 bg-energy-dark/20 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-energy-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-white mb-3">
            Vous avez un projet et vous voulez co-construire ?
          </h3>
          <p class="text-white/50 text-sm leading-relaxed mb-6">
            Vous avez un projet avec la capacité à le traduire sur des choses impactantes. 
            Pas juste un budget — un passage à l'acte.
          </p>
          <p class="text-energy-green font-display font-semibold text-sm">
            Pensez à nous →
          </p>
        </div>
      </div>

      <!-- Card: Budget-seekers -->
      <div class="reveal reveal-delay-2">
        <div class="bg-white/[0.03] rounded-2xl p-8 border border-white/10 h-full">
          <div class="w-12 h-12 bg-white/[0.04] rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-white/40 mb-3">
            Vous cherchez uniquement un budget ?
          </h3>
          <p class="text-white/30 text-sm leading-relaxed mb-6">
            Si c'est juste pour voir si vous êtes éligible à un financement — 
            ce n'est pas le bon endroit. La méthode EC²R est au service de votre projet, 
            pas l'inverse.
          </p>
          <p class="text-white/30 font-display font-semibold text-sm">
            Oubliez-nous.
          </p>
        </div>
      </div>
    </div>

    <!-- Contact form + booking -->
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24">
      
      <!-- Left: human touch -->
      <div class="reveal">
        <div class="space-y-6 text-white/50 text-sm">
          <p class="flex items-center gap-3">
            <svg class="w-5 h-5 text-energy-green flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Il y a un protocole pour « en être » — pas ouvert à tous
          </p>
          <p class="flex items-center gap-3">
            <svg class="w-5 h-5 text-energy-green flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Toujours un interlocuteur EC²R avant engagement
          </p>
          <p class="flex items-center gap-3">
            <svg class="w-5 h-5 text-energy-green flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            10 minutes — si ça résonne, on avance
          </p>
          <p class="flex items-center gap-3">
            <svg class="w-5 h-5 text-energy-green flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            La différence entre gagner et avoir raison
          </p>
        </div>

        <!-- Booking CTA -->
        <div class="mt-10 bg-white/[0.04] rounded-xl p-6 border border-white/10">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 rounded-lg bg-energy-dark/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-energy-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
              </svg>
            </div>
            <div>
              <h4 class="font-display font-semibold text-white text-sm">Réserver un créneau</h4>
              <p class="text-white/40 text-xs">10 min, pas de pitch, juste une conversation.</p>
            </div>
          </div>
          <a href="#" class="btn-primary w-full justify-center bg-energy-dark hover:bg-energy-green hover:text-navy-950 text-sm py-3">
            Choisir un créneau
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <p class="text-white/20 text-xs text-center mt-3">
            Connexion agenda à venir — en attendant, écrivez-nous.
          </p>
        </div>

        <!-- Arrogant touch -->
        <div class="mt-8 pt-8 border-t border-white/5">
          <p class="text-white/20 text-xs italic leading-relaxed">
            « Si vous voulez nous copier, oubliez-nous. La méthode a dépassé l'homme — 
            elle est auto-entretenue et évolutive. Ce sont les artistes et ceux qui ont une méthode 
            en propre qui réussissent. »
          </p>
        </div>
      </div>

      <!-- Right: form -->
      <div class="reveal reveal-delay-2">
        <form 
          action="#" 
          method="POST"
          class="bg-white/5 backdrop-blur-sm rounded-xl p-8 border border-white/10 space-y-5"
        >
          <div>
            <label for="name" class="block text-white/70 text-sm font-medium mb-2">Nom</label>
            <input 
              type="text" id="name" name="name" required
              class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white text-base 
                     placeholder-white/30 focus:outline-none focus:border-energy-green/50 
                     focus:ring-1 focus:ring-energy-green/30 transition-colors"
              placeholder="Votre nom"
            />
          </div>

          <div>
            <label for="email" class="block text-white/70 text-sm font-medium mb-2">Email</label>
            <input 
              type="email" id="email" name="email" required
              class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white text-base 
                     placeholder-white/30 focus:outline-none focus:border-energy-green/50 
                     focus:ring-1 focus:ring-energy-green/30 transition-colors"
              placeholder="votre@email.com"
            />
          </div>

          <div>
            <label for="intent" class="block text-white/70 text-sm font-medium mb-2">Votre situation</label>
            <select
              id="intent" name="intent"
              class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white text-base 
                     focus:outline-none focus:border-energy-green/50 
                     focus:ring-1 focus:ring-energy-green/30 transition-colors"
            >
              <option value="" class="bg-navy-950">Choisir...</option>
              <option value="parler" class="bg-navy-950">Vous voulez nous en parler</option>
              <option value="prescrire" class="bg-navy-950">Vous voulez nous prescrire</option>
              <option value="experimenter" class="bg-navy-950">Vous voulez expérimenter</option>
            </select>
          </div>

          <div>
            <label for="referral" class="block text-white/70 text-sm font-medium mb-2">
              Qui vous en a parlé ?
            </label>
            <input 
              type="text" id="referral" name="referral"
              class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white text-base 
                     placeholder-white/30 focus:outline-none focus:border-energy-green/50 
                     focus:ring-1 focus:ring-energy-green/30 transition-colors"
              placeholder="Nom de la personne ou contexte"
            />
          </div>

          <div>
            <label for="message" class="block text-white/70 text-sm font-medium mb-2">Message</label>
            <textarea 
              id="message" name="message" rows="3"
              class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white text-base 
                     placeholder-white/30 focus:outline-none focus:border-energy-green/50 
                     focus:ring-1 focus:ring-energy-green/30 transition-colors resize-none"
              placeholder="Ce qui vous amène, votre contexte..."
            ></textarea>
          </div>

          <div class="flex items-start gap-3">
            <input 
              type="checkbox" id="consent" name="consent" required
              class="mt-1 w-4 h-4 rounded border-white/20 bg-white/5 text-energy-green 
                     focus:ring-energy-green/30 focus:ring-offset-0 cursor-pointer"
            />
            <label for="consent" class="text-white/50 text-xs leading-relaxed cursor-pointer">
              J'accepte que mes données soient traitées par EC²R Conseil pour répondre à ma demande, 
              conformément à la <a href="/politique-de-confidentialite" class="text-energy-green/70 hover:text-energy-green underline">politique de confidentialité</a>.
            </label>
          </div>

          <button type="submit" class="btn-primary w-full justify-center bg-energy-dark hover:bg-energy-green hover:text-navy-950">
            Engager la conversation
          </button>

          <p class="text-white/30 text-xs text-center">
            Nous répondons personnellement. Pas d'auto-répondeur.
          </p>
        </form>
      </div>

    </div>
  </div>
</section>
