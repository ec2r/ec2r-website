---
const links = [
  { href: '#methode', label: 'La Méthode' },
  { href: '#preuves', label: 'Ils le vivent' },
  { href: '#protocole', label: 'Le Protocole' },
  { href: '#equipe', label: 'Les Praticiens' },
  { href: '#contact', label: 'Parlons-en' },
];
---

<!-- Scroll progress bar -->
<div id="scroll-progress"></div>

<nav id="nav" class="fixed top-[3px] left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 flex items-center justify-between h-16 lg:h-20">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-3 group">
      <img 
        src="/images/logo-ec2r.png" 
        alt="EC²R" 
        class="h-8 lg:h-9 nav-logo-img transition-all duration-300"
      />
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="nav-link text-sm font-medium tracking-wide transition-colors duration-200 
                   text-white/70 hover:text-white
                   relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-0.5 
                   after:bg-energy-green after:transition-all after:duration-300
                   hover:after:w-full [&.active]:after:w-full [&.active]:text-white"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" class="md:hidden text-white p-2" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="menu-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        <path id="menu-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-navy-950/98 backdrop-blur-lg border-t border-white/10">
    <ul class="px-6 py-4 space-y-1">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="mobile-nav-link block py-3 text-white/80 hover:text-white font-medium transition-colors"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const nav = document.getElementById('nav')!;
  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const menuOpen = document.getElementById('menu-open')!;
  const menuClose = document.getElementById('menu-close')!;
  const progress = document.getElementById('scroll-progress')!;

  // Scroll: transparent → solid bg + progress bar
  let scrolled = false;
  window.addEventListener('scroll', () => {
    const isScrolled = window.scrollY > 40;
    if (isScrolled !== scrolled) {
      scrolled = isScrolled;
      nav.classList.toggle('bg-navy-950/95', isScrolled);
      nav.classList.toggle('backdrop-blur-lg', isScrolled);
      nav.classList.toggle('shadow-lg', isScrolled);
    }

    // Update scroll progress
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const scrollPercent = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
    progress.style.width = scrollPercent + '%';
  });

  // Mobile toggle
  toggle.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden');
    menuOpen.classList.toggle('hidden');
    menuClose.classList.toggle('hidden');
  });

  // Close on link click
  menu.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      menuOpen.classList.remove('hidden');
      menuClose.classList.add('hidden');
    });
  });

  // Close on scroll
  window.addEventListener('scroll', () => {
    if (!menu.classList.contains('hidden')) {
      menu.classList.add('hidden');
      menuOpen.classList.remove('hidden');
      menuClose.classList.add('hidden');
    }
  });
</script>
