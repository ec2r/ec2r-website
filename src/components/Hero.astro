---
import Battery from './Battery.astro';
---

<section id="accueil" class="relative min-h-screen flex items-center overflow-hidden bg-navy-950">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-navy-950"></div>
  
  <!-- Futuristic grid overlay -->
  <div class="absolute inset-0 grid-overlay"></div>
  
  <!-- Subtle geometric decoration -->
  <div class="absolute top-1/4 right-0 w-[600px] h-[600px] rounded-full border border-white/[0.03] translate-x-1/3"></div>
  <div class="absolute bottom-1/3 left-0 w-[500px] h-[500px] rounded-full border border-energy-dark/[0.06] -translate-x-1/3"></div>
  <div class="absolute top-1/2 right-1/4 w-[300px] h-[300px] rounded-full bg-energy-dark/[0.02] blur-3xl"></div>

  <!-- Energy gradient line at top -->
  <div class="absolute top-0 left-0 right-0 energy-gradient-bar h-1"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full py-20 sm:py-24 lg:py-0">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-20 items-center">
      
      <!-- Text -->
      <div class="order-2 lg:order-1">
        <p class="text-energy-green text-sm font-semibold tracking-[0.2em] uppercase mb-6 animate-fade-in" style="animation-delay: 0.2s">
          Méthode EC²R ©
        </p>

        <h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-display font-extrabold text-white leading-[1.1] mb-4 opacity-0 animate-fade-up" style="animation-delay: 0.4s">
          Nos énergies<br/>
          <span class="energy-gradient-text">plus collectives</span>
        </h1>

        <!-- Animated rotating tagline -->
        <div class="text-2xl md:text-3xl font-display font-bold text-white/80 mb-8 h-[2.5em] md:h-[2em] opacity-0 animate-fade-up" style="animation-delay: 0.6s">
          <span class="text-white/50">pour </span>
          <span id="rotating-tagline" class="rotating-words">
            <span class="word active">une croissance plus responsable</span>
            <span class="word">un changement plus réaliste</span>
            <span class="word">des résultats plus concrets</span>
            <span class="word">une réactivité plus collective</span>
          </span>
        </div>

        <p class="text-lg md:text-xl text-white/60 leading-relaxed max-w-lg mb-4 opacity-0 animate-fade-up" style="animation-delay: 0.8s">
          Pas le Netflix de la formation.<br/>
          Le <strong class="text-white">Waze du comportement professionnel</strong>.
        </p>
        <p class="text-base text-white/40 leading-relaxed max-w-lg mb-10 opacity-0 animate-fade-up" style="animation-delay: 0.95s">
          Un IRM organisationnel qui mesure les énergies collectives, identifie chirurgicalement 
          les leviers de mobilisation et accompagne le passage à l'acte. 
          Pour que les collaborateurs s'engagent vraiment — pas juste qu'ils soient bien au travail.
        </p>

        <div class="flex flex-wrap gap-4 opacity-0 animate-fade-up" style="animation-delay: 1.1s">
          <a href="#methode" class="btn-primary w-full sm:w-auto justify-center">
            Découvrir la méthode
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
          <a href="#contact" class="btn-secondary border-white/20 text-white/70 hover:bg-white/10 hover:text-white hover:border-white/40 w-full sm:w-auto justify-center">
            Parlons-en
          </a>
        </div>
      </div>

      <!-- Battery visual -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
        <div class="w-40 md:w-48 lg:w-56 opacity-0 animate-fade-in battery-glow" style="animation-delay: 0.3s">
          <Battery />
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/30 animate-bounce">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

<script>
  // Rotating tagline words
  const container = document.getElementById('rotating-tagline');
  if (container) {
    const words = container.querySelectorAll('.word');
    let current = 0;

    setInterval(() => {
      words[current].classList.remove('active');
      current = (current + 1) % words.length;
      words[current].classList.add('active');
    }, 3000);
  }
</script>
