---
import Battery from './Battery.astro';
/**
 * Section temporaire pour revoir l'animation batterie.
 * A SUPPRIMER après validation.
 */

const levels = [
  { color: 'bg-green-800', label: 'Aligné', desc: 'Le collectif est en mouvement, autonome.' },
  { color: 'bg-green-500', label: 'Engagé', desc: 'L\'énergie est là, les actions suivent.' },
  { color: 'bg-[#C9A56E]', label: 'Neutre', desc: 'Ni frein ni moteur. Zone d\'observation.' },
  { color: 'bg-yellow-500', label: 'Préoccupé', desc: 'Signaux faibles, tension latente.' },
  { color: 'bg-red-600', label: 'Divergent', desc: 'Désalignement visible, action urgente.' },
];
---

<section id="battery-demo" class="relative py-24 bg-navy-950 border-t border-white/10 overflow-hidden">
  <!-- Banner -->
  <div class="bg-yellow-500/10 border border-yellow-500/30 text-yellow-300 text-sm text-center py-2 mb-12 mx-6 rounded-lg">
    SECTION TEMPORAIRE — Aperçu de l'animation batterie
  </div>

  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      
      <!-- Battery at larger scale -->
      <div class="flex justify-center">
        <div class="w-56 md:w-64 lg:w-72 battery-glow">
          <Battery />
        </div>
      </div>

      <!-- Legend -->
      <div>
        <h2 class="text-2xl md:text-3xl font-display font-bold text-white mb-3">
          La batterie des énergies
        </h2>
        <p class="text-white/50 mb-8 text-lg">
          Signature visuelle EC²R — 5 niveaux d'énergie collective, du rouge au vert.
        </p>

        <div class="space-y-4">
          {levels.map((level, i) => (
            <div class="flex items-start gap-4 group" style={`animation: fadeSlideIn 0.4s ease-out ${0.3 + i * 0.15}s both`}>
              <div class={`w-4 h-4 rounded-sm ${level.color} mt-1 flex-shrink-0 group-hover:scale-125 transition-transform`}></div>
              <div>
                <span class="text-white font-semibold">{level.label}</span>
                <span class="text-white/40 ml-2 text-sm">{level.desc}</span>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-10 p-4 bg-white/5 rounded-lg border border-white/10">
          <p class="text-white/60 text-sm">
            <span class="text-energy-green font-semibold">Animation :</span> les cellules se remplissent du bas (Divergent) vers le haut (Aligné) avec un effet de glow continu sur la cellule sommitale.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeSlideIn {
    from {
      opacity: 0;
      transform: translateX(-12px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
</style>
